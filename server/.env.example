# Server Configuration
PORT=4000
NODE_ENV=development

# Twilio Configuration (Optional - for SMS/WhatsApp OTP)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=
TWILIO_SMS_FROM=

# Supabase Configuration
# Get these from your Supabase project settings > API
SUPABASE_URL=https://luvbuvwjseeurwpypvda.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
# You can also use anon key if service role key is not available
# SUPABASE_ANON_KEY=your-anon-key-here

# Database Connection String (for migrations)
# Get this from Supabase Dashboard > Settings > Database > Connection string (URI)
# Format: postgresql://postgres:[YOUR-PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres
DATABASE_URL=postgresql://postgres:your-password@db.luvbuvwjseeurwpypvda.supabase.co:5432/postgres

# File Upload Configuration
MAX_FILE_SIZE=5242880
UPLOAD_DIR=./uploads/photos
